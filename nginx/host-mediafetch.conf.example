# Optional host-level TLS proxy for deployments where Compose listens only on
# 127.0.0.1:18080. Replace mediafetch.example.com and certificate paths.
server {
    listen 443 ssl http2;
    listen [::]:443 ssl http2;
    server_name mediafetch.example.com;
    client_max_body_size 32k;

    ssl_certificate /etc/letsencrypt/live/mediafetch.example.com/fullchain.pem;
    ssl_certificate_key /etc/letsencrypt/live/mediafetch.example.com/privkey.pem;

    location ^~ /api/v1/files/ {
        access_log off;
        proxy_pass http://127.0.0.1:18080;
        proxy_http_version 1.1;
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto https;
        proxy_set_header Connection "";

        # Keep several megabytes ready for the TLS client without writing a
        # second copy of large files to the host proxy's temporary directory.
        proxy_buffering on;
        proxy_buffer_size 128k;
        proxy_buffers 32 256k;
        proxy_busy_buffers_size 2m;
        proxy_max_temp_file_size 0;
        proxy_read_timeout 3700s;
        proxy_send_timeout 3700s;
    }

    location / {
        proxy_pass http://127.0.0.1:18080;
        proxy_http_version 1.1;
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto https;
        proxy_set_header Connection "";
        proxy_buffering off;
        proxy_read_timeout 3700s;
    }
}
