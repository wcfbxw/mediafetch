# Copy this file to .env before starting the stack.
APP_ENV=production
LOG_LEVEL=INFO
REDIS_URL=redis://redis:6379/0
PUBLIC_BASE_URL=http://localhost
ALLOWED_ORIGINS=https://example.com
X_ACCEL_REDIRECT_ENABLED=true

# Generate a unique value for every deployment with: openssl rand -hex 32
TOKEN_SECRET=

# Protects the hidden /admin platform-login console. Generate independently
# with: openssl rand -hex 32
ADMIN_TOKEN=
CREDENTIALS_ROOT=/credentials

MAX_CONCURRENT_JOBS_PER_IP=2
MAX_GLOBAL_WORKERS=2
WORKER_CPU_LIMIT=4.0
MAX_QUEUE_SIZE=100
MAX_FILE_SIZE_MB=2048
MAX_DURATION_SECONDS=10800
DOWNLOAD_TIMEOUT_SECONDS=3600
FFMPEG_TIMEOUT_SECONDS=1800
FFMPEG_THREADS=2
FFMPEG_X264_PRESET=veryfast
INSPECT_TIMEOUT_SECONDS=45
INSPECT_CACHE_TTL_SECONDS=600
FILE_TTL_SECONDS=7200
JOB_TTL_SECONDS=86400
CLEANUP_INTERVAL_SECONDS=300
MAX_REDIRECTS=5
RATE_LIMIT_INSPECT_PER_MINUTE=20
RATE_LIMIT_DOWNLOAD_PER_MINUTE=10
AUDIO_MP3_QUALITY=2

# Optional outbound proxy configured by the operator, never by API users.
YTDLP_PROXY=
# Enables the hardened HTTP Range downloader for direct Bilibili media URLs.
# Keep the connection count moderate to avoid CDN throttling or rate limits.
PARALLEL_DOWNLOAD_ENABLED=true
PARALLEL_DOWNLOAD_CONNECTIONS=8
PARALLEL_DOWNLOAD_MIN_SPLIT_SIZE_MB=4
# Reconnect after each bounded chunk so a CDN cannot kill one long response.
PARALLEL_DOWNLOAD_CHUNK_SIZE_MB=4
# Fixed server-controlled browser identity used for Bilibili login and media requests.
BILIBILI_USER_AGENT=Mozilla/5.0 (Windows NT 10.0; Win64; x64) AppleWebKit/537.36 (KHTML, like Gecko) Chrome/143.0.0.0 Safari/537.36
NEXT_PUBLIC_API_BASE=/api/v1
